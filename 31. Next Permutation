class Solution {
public:
    void nextPermutation(vector<int>& nums) {

        int n = nums.size();

        // Step 1: Find the pivot element
        // Pivot is the first element from the right
        // which is smaller than its next element.
        int piv = -1;

        for (int i = n - 2; i >= 0; i--) {
            if (nums[i] < nums[i + 1]) {
                piv = i;
                break;
            }
        }

        // Step 2: If no pivot is found,
        // the array is the last permutation.
        // Reverse it to get the first permutation.
        if (piv == -1) {
            reverse(nums.begin(), nums.end());
            return;
        }

        // Step 3: Find the next greater element
        // from the right side of the pivot.
        for (int i = n - 1; i > piv; i--) {
            if (nums[i] > nums[piv]) {
                swap(nums[i], nums[piv]);
                break;
            }
        }

        // Step 4: Reverse the elements
        // after the pivot to get the next permutation.
        // reverse(nums.begin() + piv + 1, nums.end());
        int i = piv + 1, j = n - 1;
        while (i <= j) {
            swap(nums[i++], nums[j--]);
        }
    }
};
