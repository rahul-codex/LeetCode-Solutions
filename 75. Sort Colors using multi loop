class Solution {
public:
    void sortColors(vector<int>& nums) {
        int n = nums.size(), cou0 = 0, cou1 = 0, cou2 = 0;
        for (int i = 0; i < n; i++) {
            if (nums[i] == 0)
                cou0++;

            if (nums[i] == 1)
                cou1++;

            if (nums[i] == 2)
                cou2++;
        }
        int ind = 0;
        for (int i = 0; i < cou0; i++) {
            nums[ind++] = 0;
        }
        for (int i = 0; i < cou1; i++) {
            nums[ind++] = 1;
        }
        for (int i = 0; i < cou2; i++) {
            nums[ind++] = 2;
        }
    }
};
