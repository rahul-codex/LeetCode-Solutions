#include <stdio.h>

int getValue(char ch)
{
    if(ch == 'I') return 1;
    if(ch == 'V') return 5;
    if(ch == 'X') return 10;
    if(ch == 'L') return 50;
    if(ch == 'C') return 100;
    if(ch == 'D') return 500;
    if(ch == 'M') return 1000;
    return 0;
}

int romanToInt(char* s) 
{
    int total = 0;
    int i = 0;

    while(s[i] != '\0')
    {
        int curr = getValue(s[i]);
        int next = getValue(s[i+1]);

        if(curr < next)
        {
            total = total - curr;
        }
        else
        {
            total = total + curr;
        }

        i++;
    }

    return total;
}