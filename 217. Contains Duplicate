// Brute Force Approach
// Compare every element with all remaining elements.
// Time Complexity: O(n²)
// Space Complexity: O(1)
-------------------------------------------


class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        int n = nums.size();
       for (int i = 0;i < n-1;i++){
           for(int j = i+1;j<n;j++){
              if(nums[i] == nums[j]){ 
               return true;
               }
           }
       }
       return false;
    }
};


// Sorting Approach
// Sort the array and check adjacent elements for duplicates.
// Time Complexity: O(n log n)
// Space Complexity: O(1) (ignoring the sorting implementation)
-------------------------------------------

class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        sort(nums.begin(), nums.end());

        for (int i = 0; i < nums.size() - 1; i++) {
            if (nums[i] == nums[i + 1]) {
                return true;
            }
        }

        return false;
    }
};


// Hash Set Approach (Optimal)
// Store visited elements in an unordered_set.
// If an element is already present, return true.
// Time Complexity: O(n) (average)
// Space Complexity: O(n)
-----------------------------------------------


class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        unordered_set<int> st;

        for (int i = 0; i < nums.size(); i++) {
            if (st.find(nums[i]) != st.end()) {
                return true;
            }
            st.insert(nums[i]);
        }

        return false;
    }
};

