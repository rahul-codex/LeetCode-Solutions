class Solution {
public:
    // Bug Fix 1 & 2: Pass 'mid' as the row index, rename to 'row_idx' for
    // clarity. Bug Fix 3: Compare against 'matrix[row_idx][mide]' instead of
    // indices or target.
    bool searchinrow(vector<vector<int>>& matrix, int target, int row_idx) {
        int n = matrix[0].size();
        int st = 0, end = n - 1;

        while (st <= end) {
            int mide = st + (end - st) / 2;

            if (matrix[row_idx][mide] == target) {
                return true;
            } else if (target > matrix[row_idx][mide]) {
                st = mide + 1;
            } else {
                end = mide - 1;
            }
        }
        return false;
    }

    bool searchMatrix(vector<vector<int>>& matrix, int target) {
        if (matrix.empty() || matrix[0].empty())
            return false;

        int m = matrix.size(), n = matrix[0].size();
        int startRow = 0, endRow = m - 1;

        while (startRow <= endRow) {
            int mid = startRow + (endRow - startRow) / 2;

            if (target >= matrix[mid][0] && target <= matrix[mid][n - 1]) {
                // Bug Fix 1: Properly forward 'mid' as the chosen row to search
                return searchinrow(matrix, target, mid);
            } else if (target > matrix[mid][n - 1]) {
                startRow = mid + 1;
            } else {
                endRow = mid - 1;
            }
        }
        return false;
    }
};
